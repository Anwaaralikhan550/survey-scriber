# ============================================
# SurveyScriber Backend - PRODUCTION Environment
# ============================================
# SECURITY: This file is a TEMPLATE. DO NOT commit actual secrets!
#
# For cloud deployment:
# - Use your cloud provider's secrets manager (AWS Secrets Manager, GCP Secret Manager, etc.)
# - Or set environment variables directly in your deployment platform
# ============================================

# Application
NODE_ENV=production
PORT=3000
API_PREFIX=api
APP_NAME=SurveyScriber API
APP_VERSION=1.0.0

# ============================================
# DATABASE (REQUIRED)
# ============================================
# IMPORTANT: Always use SSL in production
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://surveyscriber:REPLACE_WITH_STRONG_PASSWORD@your-db-host.com:5432/surveyscriber_db?sslmode=require"

# ============================================
# JWT SECRETS (REQUIRED - SECURITY CRITICAL)
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# REQUIREMENTS:
# - Minimum 64 characters
# - Must NOT contain: 'default', 'secret', 'password', 'test', 'example', 'changeme'
# - Must be cryptographically random
# - App will REFUSE TO START with weak secrets in production
#
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_ACCESS_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_REFRESH_SECRET
REFRESH_TOKEN_EXPIRES_DAYS=7

# Password Hashing
BCRYPT_SALT_ROUNDS=12

# Logging (production should use 'warn' or 'error')
LOG_LEVEL=warn

# ============================================
# CORS (REQUIRED)
# ============================================
# Comma-separated list of allowed origins
# IMPORTANT: In production, this MUST be set explicitly
# Example: https://surveyscriber.com,https://www.surveyscriber.com
CORS_ORIGINS=https://your-production-domain.com

# ============================================
# MEDIA STORAGE
# ============================================
MEDIA_STORAGE_DRIVER=local
MEDIA_LOCAL_ROOT=/app/storage
MAX_UPLOAD_MB_PHOTO=10
MAX_UPLOAD_MB_AUDIO=30
MAX_UPLOAD_MB_SIGNATURE=5

# ============================================
# EMAIL (for password reset)
# ============================================
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_USER=your-email@domain.com
# SMTP_PASS=your-email-password
# SMTP_FROM=noreply@surveyscriber.com
