# ===========================================
# SurveyScriber Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api
APP_NAME=SurveyScriber API
APP_VERSION=1.0.0

# ===========================================
# Database Configuration
# ===========================================
# Local development (no SSL required):
DATABASE_URL="postgresql://surveyscriber:surveyscriber_secret@localhost:5432/surveyscriber_db?schema=public"

# PRODUCTION: Always use SSL! Add ?sslmode=require
# Example: DATABASE_URL="postgresql://user:pass@host:5432/db?sslmode=require"

# ===========================================
# JWT Authentication (SECURITY CRITICAL)
# ===========================================
# IMPORTANT: You MUST generate secure random secrets for production!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# Requirements:
# - Minimum 32 characters
# - Must NOT contain: 'default', 'secret', 'password', 'test', 'example', 'changeme'
# - In production: App will FAIL TO START with default/insecure secrets
#
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_FOR_ACCESS_TOKEN
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_FOR_REFRESH_TOKEN
REFRESH_TOKEN_EXPIRES_DAYS=7

# Password Hashing
BCRYPT_SALT_ROUNDS=12

# Logging
LOG_LEVEL=debug

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
